{
	"trailingComma": "es5",
	"arrowParens": "always",
	"bracketSpacing": true,
	"semi": true,
	"singleQuote": true,
	"jsxSingleQuote": false,
	"proseWrap": "preserve",
	"useTabs": true,
	"printWidth": 80,
	"endOfLine": "lf",
	"overrides": [
		{
			"files": "*.json",
			"options": {
				"printWidth": 100
			}
		}
	]
}
